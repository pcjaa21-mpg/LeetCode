#include <string>
#include <unordered_map>

using namespace std;

class Solution {
public:
    int romanToInt(string s) {
        unordered_map<char, int> m = {
            {'I', 1}, {'V', 5}, {'X', 10}, {'L', 50},
            {'C', 100}, {'D', 500}, {'M', 1000}
        };
        
        int result = 0;
        for (int i = 0; i < s.length(); i++) {
            // If current value is less than the next value, subtract it
            if (i + 1 < s.length() && m[s[i]] < m[s[i + 1]]) {
                result -= m[s[i]];
            } else {
                result += m[s[i]];
            }
        }
        return result;
    }
};

#include <vector>
#include <cmath>
#include <algorithm>

using namespace std;

class Solution {
public:
    int getMinDistance(vector<int>& nums, int target, int start) 
    {
        int min_dist = nums.size(); 

        for (int i = 0; i < nums.size(); i++) 
        {
            if (nums[i] == target) 
            {
               
                min_dist = min(min_dist, abs(i - start));
                
               if (min_dist == 0) break;
            }
        }
        
        return min_dist;
    }
};

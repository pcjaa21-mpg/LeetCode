#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    double findMedianSortedArrays(vector<int>& nums1, vector<int>& nums2) {
        int total = nums1.size() + nums2.size();
        if (total % 2 == 1) {
            return findKth(nums1, 0, nums2, 0, total / 2 + 1);
        } else {
            return (findKth(nums1, 0, nums2, 0, total / 2) + 
                    findKth(nums1, 0, nums2, 0, total / 2 + 1)) / 2.0;
        }
    }

private:
    int findKth(vector<int>& n1, int i, vector<int>& n2, int j, int k) {
        if (n1.size() - i > n2.size() - j) return findKth(n2, j, n1, i, k);
        if (i == n1.size()) return n2[j + k - 1];
        if (k == 1) return min(n1[i], n2[j]);

        int p1 = min((int)n1.size(), i + k / 2);
        int p2 = j + k - (p1 - i);

        if (n1[p1 - 1] < n2[p2 - 1])
            return findKth(n1, p1, n2, j, k - (p1 - i));
        else
            return findKth(n1, i, n2, p2, k - (p2 - j));
    }
};
